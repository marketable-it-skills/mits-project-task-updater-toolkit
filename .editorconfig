# https://editorconfig.org — VS Code / Cursor apply charset on save when supported
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
charset = utf-8

[*.json]
charset = utf-8
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false
